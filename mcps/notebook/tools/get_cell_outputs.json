{
  "name": "get_cell_outputs",
  "description": "Read outputs from a code cell by index",
  "inputSchema": {
    "type": "object",
    "properties": {
      "notebookPath": {
        "type": "string",
        "description": "Path to the notebook file"
      },
      "cellIndex": {
        "type": "number",
        "description": "0-based index of the cell to inspect"
      }
    },
    "required": [
      "notebookPath",
      "cellIndex"
    ]
  }
}