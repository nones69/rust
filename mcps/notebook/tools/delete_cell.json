{
  "name": "delete_cell",
  "description": "Delete a specific cell from a notebook",
  "inputSchema": {
    "type": "object",
    "properties": {
      "notebookPath": {
        "type": "string",
        "description": "Path to the notebook file"
      },
      "cellIndex": {
        "type": "number",
        "description": "0-based index of the cell to delete"
      }
    },
    "required": [
      "notebookPath",
      "cellIndex"
    ]
  }
}