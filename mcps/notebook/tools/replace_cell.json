{
  "name": "replace_cell",
  "description": "Replace the content of a specific cell in a notebook",
  "inputSchema": {
    "type": "object",
    "properties": {
      "notebookPath": {
        "type": "string",
        "description": "Path to the notebook file"
      },
      "cellIndex": {
        "type": "number",
        "description": "0-based index of the cell to replace"
      },
      "content": {
        "type": "string",
        "description": "New content of the cell"
      }
    },
    "required": [
      "notebookPath",
      "cellIndex",
      "content"
    ]
  }
}