{
  "name": "read_cell",
  "description": "Read the content of a specific cell in a notebook",
  "inputSchema": {
    "type": "object",
    "properties": {
      "notebookPath": {
        "type": "string",
        "description": "Path to the notebook file"
      },
      "cellIndex": {
        "type": "number",
        "description": "0-based index of the cell"
      }
    },
    "required": [
      "notebookPath",
      "cellIndex"
    ]
  }
}